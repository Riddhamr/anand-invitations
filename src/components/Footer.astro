---
import { couple, eventDate, bride, groom } from '../data/engagement';
// Footer always shows the couple's nicknames — Mimi & Riri forever —
// independent of the invitedBy / ?v= ordering used elsewhere.
---
<footer class="bg-ink text-cream py-16 px-6 text-center overflow-hidden">
  <p class="font-cinzel text-xs tracking-[0.4em] text-gold-soft" data-reveal="up">WITH LOVE</p>
  <h3 class="font-names text-5xl sm:text-6xl text-cream mt-3 leading-[1.3]" data-reveal="zoom" data-delay="100">
    <span class="block" style="word-spacing: 0.2em">{bride.nickname}</span>
    <span class="block text-4xl sm:text-5xl text-gold-soft">&</span>
    <span class="block" style="word-spacing: 0.2em">{groom.nickname}</span>
    <span class="block mt-2 text-3xl sm:text-4xl text-gold-soft italic">forever</span>
  </h3>
  <div class="my-5 flex items-center justify-center gap-3" data-reveal="up" data-delay="200">
    <span class="h-px w-12 bg-gold-soft/40"></span>
    <span class="text-2xl">💐</span>
    <span class="h-px w-12 bg-gold-soft/40"></span>
  </div>
  <p class="font-serif-display text-lg italic text-cream/90" data-reveal="up" data-delay="300">
    {eventDate.display}
  </p>
  <!-- No data-reveal: this is the last element on the page and would sit inside
       the IntersectionObserver's bottom margin, so the reveal never fires and it
       stayed invisible. Render it plainly so the hashtag is always visible. -->
  <p class="mt-3 font-cinzel text-sm tracking-[0.3em] text-gold-soft">
    {couple.hashtag}
  </p>
</footer>
