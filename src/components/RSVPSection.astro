---
import Divider from './Divider.astro';
import { rsvpMaxGuests, rsvpContactPhone } from '../data/engagement';

interface Props {
  rsvpEnabled?: boolean;
  maxGuests?: number;
  defaultGuests?: number;
  variant?: string | null;
  contactPhone?: string;
}
const {
  rsvpEnabled = true,
  maxGuests = rsvpMaxGuests,
  defaultGuests = 0,
  variant = null,
  contactPhone = rsvpContactPhone,
} = Astro.props;

const limited = defaultGuests > 0;  // a capped -N variant
const telHref = `tel:${contactPhone.replace(/[^+\d]/g, '')}`;
---
<section class="relative py-16 px-6 bg-cream overflow-hidden" id="rsvp" data-variant={variant ?? ''}>
  <div class="relative z-10 max-w-sm mx-auto text-center">
    <p class="font-cinzel text-sm text-sage-deep tracking-widest" data-reveal="up">YOU ARE INVITED</p>
    <h2 class="font-script text-4xl sm:text-5xl text-rose-deep mt-4 tracking-wide" style="word-spacing: 0.25em" data-reveal="up" data-delay="100">Will You Join Us?</h2>
    <div data-reveal="zoom" data-delay="200" class="-my-3"><Divider /></div>

    <p id="rsvp-intro" class="font-serif-display italic text-base text-foreground/90 mb-3" data-reveal="up" data-delay="200">
      {rsvpEnabled ? 'Let us know so we can celebrate together.' : "We'd love to have you with us."}
    </p>

    {!rsvpEnabled ? (
      <div class="bg-white/70 border border-gold-soft rounded-2xl px-7 py-8 shadow-soft text-center" data-reveal="zoom" data-delay="300">
        <p class="text-3xl mb-3">💌</p>
        <p class="font-serif-display text-lg text-foreground/90 leading-relaxed">
          Something doesn't look right with your invitation link.
        </p>
        <p class="font-serif-display text-base text-foreground/70 mt-3 leading-relaxed">
          Please text or call us to confirm your RSVP:
        </p>
        <a href={telHref} class="inline-block mt-4 px-6 py-3 rounded-full gradient-gold text-white font-cinzel text-sm tracking-widest shadow-gold hover:opacity-90 active:scale-95 transition-all duration-200">
          {contactPhone}
        </a>
      </div>
    ) : (
    <div class="bg-white/70 border border-gold-soft rounded-2xl px-7 py-7 shadow-soft text-left" data-reveal="zoom" data-delay="300">

      <div id="rsvp-success" class="hidden text-center py-6">
        <p class="font-script text-5xl text-rose mb-3">Thank You! 💐</p>
        <p class="font-serif-display text-lg text-foreground/80 italic">We can't wait to celebrate with you.</p>
      </div>

      {limited && (
        <p class="mb-5 font-serif-display italic text-sm text-rose-deep text-center bg-rose/5 border border-gold-soft/60 rounded-xl px-4 py-2">
          💑 This invitation is reserved for {maxGuests} {maxGuests === 1 ? 'guest' : 'guests'}.
        </p>
      )}

      <!-- Server/network errors only — field errors render inline below each input -->
      <p id="rsvp-error" class="hidden mb-5 font-serif-display text-sm text-red-700 bg-red-50 border border-red-200 rounded-xl px-4 py-3 text-center"></p>

      <form id="rsvp-form" class="space-y-6" novalidate>

        <!-- Q1: Name -->
        <div data-field="name">
          <label for="rsvp-name" class="block font-cinzel text-xs text-[hsl(95_32%_36%)] tracking-widest mb-2">YOUR NAME</label>
          <input id="rsvp-name" name="name" type="text" autocomplete="name" placeholder="Full name"
            style="font-family: 'Cinzel', serif;"
            class="form-glow w-full rounded-xl border-2 border-gold-soft bg-white/90 px-3 py-1.5 font-cinzel text-sm text-foreground placeholder:text-foreground/35 placeholder:font-normal focus:outline-none transition-all duration-200" />
          <p class="field-error hidden mt-2 font-serif-display text-sm text-red-600"></p>
        </div>

        <!-- Q2: Guests -->
        <div data-field="guest_count">
          <label for="guest_count" class="block font-cinzel text-xs text-[hsl(95_32%_36%)] tracking-widest mb-2">NUMBER OF GUESTS <span class="text-[9px] tracking-normal whitespace-nowrap opacity-80">(including you)</span></label>
          <input id="guest_count" name="guest_count" type="number" min="1" max={maxGuests} value={defaultGuests > 0 ? defaultGuests : undefined}
            style="font-family: 'Cinzel', serif;"
            class="form-glow w-full rounded-xl border-2 border-gold-soft bg-white/90 px-3 py-1.5 font-cinzel text-sm text-foreground focus:outline-none transition-all duration-200" />
          <p class="field-error hidden mt-2 font-serif-display text-sm text-red-600"></p>
        </div>

        <!-- Q3: Attendance — no emojis -->
        <fieldset data-field="status">
          <legend class="block font-cinzel text-xs text-[hsl(95_32%_36%)] tracking-widest mb-3">
            WILL YOU BE JOINING US? <span class="text-rose">*</span>
          </legend>
          <div class="space-y-2 pl-1">
            {[
              { value: 'confirmed', label: "Yes, we'll be there" },
              { value: 'not_sure',  label: 'Not sure yet' },
              { value: 'declined', label: "Sorry, we can't make it" },
            ].map(opt => (
              <label class="group flex items-center gap-4 cursor-pointer py-0.5">
                <input type="radio" name="status" value={opt.value} class="sr-only" />
                <span class="w-5 h-5 rounded-full border-2 border-gold-soft group-has-[:checked]:border-rose-deep group-has-[:checked]:bg-rose/10 flex items-center justify-center shrink-0 transition-all duration-200">
                  <span class="w-2.5 h-2.5 rounded-full bg-rose-deep scale-0 group-has-[:checked]:scale-100 transition-transform duration-200"></span>
                </span>
                <span class="font-serif-display text-sm tracking-normal text-foreground/90 group-has-[:checked]:text-rose-deep group-has-[:checked]:font-bold transition-colors duration-200">
                  {opt.label}
                </span>
              </label>
            ))}
          </div>
          <p class="field-error hidden mt-2 font-serif-display text-sm text-red-600"></p>
        </fieldset>

        <button type="submit" id="rsvp-submit"
          class="ripple-btn w-full mt-1 py-3 rounded-full gradient-gold text-white font-cinzel text-sm tracking-widest shadow-gold hover:opacity-90 active:scale-[0.98] transition-all duration-200 disabled:opacity-60 disabled:cursor-not-allowed">
          SEND RSVP
        </button>
      </form>
    </div>
    )}
  </div>
</section>

<style>
  /* Red outline applied to the input (or radio group) inside an errored field */
  [data-field].has-error input[type="text"],
  [data-field].has-error input[type="number"] {
    border-color: #dc2626 !important;
  }
</style>

<script>
  /* ── Button ripple ──────────────────────────────────────── */
  document.getElementById('rsvp-submit')?.addEventListener('click', function(e) {
    const btn  = this as HTMLButtonElement;
    const r    = btn.getBoundingClientRect();
    const size = Math.max(btn.offsetWidth, btn.offsetHeight);
    const el   = document.createElement('span');
    el.className = 'ripple';
    Object.assign(el.style, {
      width: size + 'px', height: size + 'px',
      left: (e.clientX - r.left - size/2) + 'px',
      top:  (e.clientY - r.top  - size/2) + 'px',
    });
    btn.appendChild(el);
    setTimeout(() => el.remove(), 600);
  });

  /* ── Inline field errors ────────────────────────────────── */
  const form    = document.getElementById('rsvp-form')    as HTMLFormElement | null;
  if (form) {
  const submit  = document.getElementById('rsvp-submit')  as HTMLButtonElement;
  const success = document.getElementById('rsvp-success') as HTMLDivElement;
  const errBox  = document.getElementById('rsvp-error')   as HTMLParagraphElement;

  function setFieldError(field: string, msg: string | null) {
    const wrap = form.querySelector<HTMLElement>(`[data-field="${field}"]`);
    if (!wrap) return;
    const errEl = wrap.querySelector<HTMLParagraphElement>('.field-error');
    if (msg) {
      wrap.classList.add('has-error');
      if (errEl) { errEl.textContent = msg; errEl.classList.remove('hidden'); }
    } else {
      wrap.classList.remove('has-error');
      if (errEl) { errEl.textContent = ''; errEl.classList.add('hidden'); }
    }
  }

  function clearAllErrors() {
    ['name', 'guest_count', 'status'].forEach(f => setFieldError(f, null));
    errBox.classList.add('hidden');
  }

  /* Clear a field's error as soon as the user edits it */
  form.querySelector('[name=name]')?.addEventListener('input', () => setFieldError('name', null));
  form.querySelector('[name=guest_count]')?.addEventListener('input', () => setFieldError('guest_count', null));
  form.querySelectorAll('[name=status]').forEach(r =>
    r.addEventListener('change', () => setFieldError('status', null))
  );

  function showServerError(msg: string) {
    errBox.textContent = msg;
    errBox.classList.remove('hidden');
    errBox.scrollIntoView({ behavior: 'smooth', block: 'center' });
  }

  /* ── Confetti on success ────────────────────────────────── */
  function launchConfetti() {
    const canvas = Object.assign(document.createElement('canvas'), {
      style: 'position:fixed;inset:0;width:100%;height:100%;z-index:9999;pointer-events:none'
    }) as HTMLCanvasElement;
    document.body.appendChild(canvas);
    canvas.width  = window.innerWidth;
    canvas.height = window.innerHeight;
    const ctx = canvas.getContext('2d')!;
    const W = canvas.width, H = canvas.height;
    const COLORS = ['#c9a96e','#e8b4a0','#d4a0b5','#a8c8a0','#f0d5c0','#b8d4c0','#f9e4d4'];

    const particles = Array.from({ length: 140 }, () => ({
      x: W * .5, y: H * .6,
      vx: (Math.random()-.5)*20,
      vy: -(Math.random()*16+8),
      r: Math.random()*5+2,
      color: COLORS[Math.floor(Math.random()*COLORS.length)],
      alpha: 1,
      rot: Math.random()*Math.PI*2,
      rotV: (Math.random()-.5)*.18,
    }));

    (function loop() {
      ctx.clearRect(0,0,W,H);
      let alive = false;
      for (const p of particles) {
        p.vy += .38; p.vx *= .99;
        p.x += p.vx; p.y += p.vy;
        p.alpha -= .0065; p.rot += p.rotV;
        if (p.alpha > 0) {
          alive = true;
          ctx.save();
          ctx.globalAlpha = Math.max(0, p.alpha);
          ctx.fillStyle = p.color;
          ctx.translate(p.x, p.y); ctx.rotate(p.rot);
          ctx.fillRect(-p.r, -(p.r*.5), p.r*2, p.r);
          ctx.restore();
        }
      }
      if (alive) requestAnimationFrame(loop); else canvas.remove();
    })();
  }

  /* ── Submit ─────────────────────────────────────────────── */
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    clearAllErrors();

    const name     = (form.querySelector<HTMLInputElement>('[name=name]')?.value ?? '').trim();
    const guestRaw = (form.querySelector<HTMLInputElement>('[name=guest_count]')?.value ?? '').trim();
    const status   = (form.querySelector<HTMLInputElement>('[name=status]:checked'))?.value ?? '';

    let firstInvalid: string | null = null;

    if (!name || name.length < 2) {
      setFieldError('name', 'Please enter your full name (at least 2 characters).');
      firstInvalid ??= 'name';
    }

    const maxGuests = parseInt((form.querySelector<HTMLInputElement>('[name=guest_count]')?.max) || '10', 10);
    const guestCount = parseInt(guestRaw, 10);
    if (guestRaw === '' || isNaN(guestCount)) {
      setFieldError('guest_count', 'Please enter the number of guests including yourself.');
      firstInvalid ??= 'guest_count';
    } else if (guestCount < 1 || guestCount > maxGuests) {
      setFieldError('guest_count', `Guest count must be between 1 and ${maxGuests}.`);
      firstInvalid ??= 'guest_count';
    }

    if (!status) {
      setFieldError('status', "Please let us know if you'll be joining.");
      firstInvalid ??= 'status';
    }

    if (firstInvalid) {
      form.querySelector<HTMLElement>(`[data-field="${firstInvalid}"]`)
        ?.scrollIntoView({ behavior: 'smooth', block: 'center' });
      return;
    }

    submit.disabled = true; submit.textContent = 'Sending…';

    const body = new FormData();
    body.append('name', name);
    body.append('guest_count', String(guestCount));
    body.append('status', status);
    // Send the raw ?v= variant — the API derives side + max + validity.
    const variant = new URLSearchParams(location.search).get('v') ?? '';
    body.append('variant', variant);

    try {
      const res = await fetch('/api/rsvp', { method: 'POST', body });
      if (res.ok) {
        form.classList.add('hidden');
        document.getElementById('rsvp-intro')?.classList.add('hidden');
        success.classList.remove('hidden');
        launchConfetti();
      } else {
        const data = await res.json().catch(() => ({})) as { error?: string; field?: string };
        if (data.field) {
          // Validation error for a specific question — show it inline at the field
          setFieldError(data.field, data.error ?? 'Please check this field.');
          form.querySelector<HTMLElement>(`[data-field="${data.field}"]`)
            ?.scrollIntoView({ behavior: 'smooth', block: 'center' });
        } else {
          showServerError(data.error ?? 'Something went wrong. Please try again.');
        }
        submit.disabled = false; submit.textContent = 'SEND RSVP';
      }
    } catch {
      showServerError('Network error. Please check your connection and try again.');
      submit.disabled = false; submit.textContent = 'SEND RSVP';
    }
  });
  } /* end if(form) */
</script>
