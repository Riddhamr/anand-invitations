---
import '../styles/global.css';
// PIN-gated dashboard: the page ships no data — enter the PIN and the
// API validates it before returning rows. A second PIN (config rsvpStalePin)
// lets you toggle individual RSVPs stale/active; stale entries are excluded
// from every counter and only appear under the STALE filter.
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>RSVP List</title>
    <meta name="robots" content="noindex, nofollow" />
  </head>

  <body class="bg-cream min-h-svh">
    <main class="max-w-md mx-auto px-4 py-8">

      <h1 class="font-sans text-sm font-bold text-[hsl(95_32%_30%)] tracking-widest text-center mb-6">
        RSVP RESPONSES
      </h1>

      <!-- PIN gate -->
      <div id="pin-gate" class="rounded-2xl border border-gold-soft bg-white/70 shadow-soft px-6 py-8 text-center">
        <p class="font-sans text-xs font-bold tracking-widest text-[hsl(95_32%_36%)] mb-4">ENTER PIN</p>
        <form id="pin-form" class="flex flex-col items-center gap-4">
          <input
            id="pin-input"
            type="password"
            inputmode="numeric"
            autocomplete="off"
            maxlength="6"
            class="w-40 text-center rounded-xl border-2 border-gold-soft bg-white px-4 py-2.5 font-sans font-bold text-2xl tracking-[0.4em] focus:outline-none focus:border-rose"
          />
          <p id="pin-error" class="hidden font-sans font-bold text-sm text-red-600"></p>
          <button
            type="submit"
            id="pin-submit"
            class="px-8 py-2.5 rounded-full gradient-gold text-white font-sans text-xs font-bold tracking-widest shadow-gold hover:opacity-90 active:scale-95 transition-all duration-200 disabled:opacity-60"
          >
            VIEW RESPONSES
          </button>
        </form>
      </div>

      <!-- Dashboard (rendered by JS after PIN accepted) -->
      <div id="dashboard" class="hidden"></div>

      <!-- Mark stale / active (separate PIN) -->
      <div id="stale-admin" class="hidden mt-5 rounded-2xl border border-gold-soft bg-white/70 shadow-soft px-5 py-5">
        <p class="font-sans text-[10px] font-bold tracking-widest text-[hsl(95_32%_36%)] text-center mb-3">
          MARK RSVP STALE / ACTIVE
        </p>
        <form id="stale-form" class="flex items-center gap-2">
          <input
            id="stale-id"
            type="number"
            min="1"
            placeholder="ID"
            class="w-20 text-center rounded-xl border-2 border-gold-soft bg-white px-2 py-2 font-sans font-bold text-base focus:outline-none focus:border-rose"
          />
          <input
            id="stale-pin"
            type="password"
            inputmode="numeric"
            autocomplete="off"
            maxlength="6"
            placeholder="PIN"
            class="flex-1 min-w-0 text-center rounded-xl border-2 border-gold-soft bg-white px-2 py-2 font-sans font-bold text-base tracking-[0.2em] focus:outline-none focus:border-rose"
          />
          <button
            type="submit"
            id="stale-submit"
            class="shrink-0 px-4 py-2 rounded-full gradient-gold text-white font-sans text-[10px] font-bold tracking-widest shadow-gold hover:opacity-90 active:scale-95 transition-all duration-200 disabled:opacity-60"
          >
            TOGGLE
          </button>
        </form>
        <p id="stale-result" class="hidden mt-3 font-sans font-bold text-sm text-center"></p>
      </div>
    </main>

    <script>
      const gate    = document.getElementById('pin-gate')!;
      const form    = document.getElementById('pin-form') as HTMLFormElement;
      const input   = document.getElementById('pin-input') as HTMLInputElement;
      const errEl   = document.getElementById('pin-error')!;
      const submit  = document.getElementById('pin-submit') as HTMLButtonElement;
      const dash    = document.getElementById('dashboard')!;
      const staleAdmin  = document.getElementById('stale-admin')!;
      const staleForm   = document.getElementById('stale-form') as HTMLFormElement;
      const staleId     = document.getElementById('stale-id') as HTMLInputElement;
      const stalePin    = document.getElementById('stale-pin') as HTMLInputElement;
      const staleSubmit = document.getElementById('stale-submit') as HTMLButtonElement;
      const staleResult = document.getElementById('stale-result')!;

      interface Row {
        id: number;
        name: string;
        guest_count: number;
        status: 'confirmed' | 'not_sure' | 'declined';
        side: 'bride' | 'groom' | null;
        stale: boolean;
      }

      const LABEL: Record<Row['status'], string> = { confirmed: 'Coming', not_sure: 'Not sure', declined: 'Not coming' };
      const COLOR: Record<Row['status'], string> = {
        confirmed: 'text-[hsl(95_32%_36%)]',
        not_sure:  'text-gold',
        declined:  'text-rose-deep',
      };

      function esc(s: string) {
        const map: Record<string, string> = {
          '&': '&amp;',
          '<': '&lt;',
          '>': '&gt;',
          '"': '&quot;',
          "'": '&#39;',
        };
        return s.replace(/[&<>"']/g, c => map[c]);
      }

      function bucket(rows: Row[], side: Row['side']) {
        const subset = rows.filter(r => r.side === side);
        const people = (st: Row['status']) => subset.filter(r => r.status === st).reduce((s, r) => s + r.guest_count, 0);
        return { total: subset.reduce((s, r) => s + r.guest_count, 0), coming: people('confirmed'), notSure: people('not_sure'), notComing: people('declined') };
      }

      let allRows: Row[] = [];
      let activeFilter: 'groom' | 'bride' | 'none' | 'stale' | null = null;
      let viewPin = '';

      function render() {
        // Stale RSVPs are excluded from EVERY counter — only the stale
        // box counts them, and only the stale filter lists them.
        const active = allRows.filter(r => !r.stale);
        const stale  = allRows.filter(r => r.stale);

        const totalRsvps = active.length;
        const people = (st: Row['status']) =>
          active.filter(r => r.status === st).reduce((s, r) => s + r.guest_count, 0);
        const peopleComing    = people('confirmed');
        const peopleNotSure   = people('not_sure');
        const peopleNotComing = people('declined');

        const sides = [
          { key: 'groom', label: 'GROOM SIDE', ...bucket(active, 'groom') },
          { key: 'bride', label: 'BRIDE SIDE', ...bucket(active, 'bride') },
          { key: 'none',  label: 'NO SIDE',    ...bucket(active, null) },
        ];

        const totalsHtml = `
          <div class="grid grid-cols-2 gap-3">
            <div class="rounded-2xl border border-gold-soft bg-white/70 shadow-soft px-4 py-5 text-center">
              <p class="font-sans text-[10px] font-bold tracking-widest text-[hsl(95_32%_36%)]">TOTAL RSVPS</p>
              <p class="font-sans font-bold text-4xl text-rose-deep mt-1">${totalRsvps}</p>
            </div>
            <div class="rounded-2xl border border-gold-soft bg-white/70 shadow-soft px-4 py-5 text-center">
              <p class="font-sans text-[10px] font-bold tracking-widest text-[hsl(95_32%_36%)]">TOTAL PEOPLE</p>
              <p class="font-sans font-bold text-4xl text-[hsl(95_32%_36%)] mt-1">${peopleComing}</p>
              <div class="mt-1 space-y-0.5 font-sans font-bold text-[13px] leading-tight">
                <p class="text-gold">Not sure ${peopleNotSure}</p>
                <p class="text-rose-deep">Not coming ${peopleNotComing}</p>
              </div>
            </div>
          </div>`;

        const sidesHtml = `
          <div class="grid grid-cols-3 gap-2 mt-3">
            ${sides.map(s => `
              <div data-filter="${s.key}" class="cursor-pointer select-none rounded-2xl border ${activeFilter === s.key ? 'border-rose-deep border-2 bg-white' : 'border-gold-soft bg-white/70'} shadow-soft px-2 py-4 text-center transition-all duration-200 hover:shadow-elegant">
                <p class="font-sans text-[9px] font-bold tracking-widest text-[hsl(95_32%_36%)] whitespace-nowrap">${s.label}</p>
                <p class="font-sans font-bold text-2xl text-[hsl(95_32%_36%)] mt-0.5">${s.coming}</p>
                <div class="mt-2 space-y-0.5 font-sans font-bold text-[13px] leading-tight">
                  <p class="text-foreground/80">Total ${s.total}</p>
                  <p class="text-gold">Not sure ${s.notSure}</p>
                  <p class="text-rose-deep">Not coming ${s.notComing}</p>
                </div>
                ${activeFilter === s.key ? '<p class="mt-2 font-sans text-[8px] font-bold tracking-widest text-rose-deep">✓ SELECTED</p>' : ''}
              </div>`).join('')}
          </div>`;

        const staleHtml = `
          <div data-filter="stale" class="cursor-pointer select-none mt-3 rounded-2xl border ${activeFilter === 'stale' ? 'border-rose-deep border-2 bg-white' : 'border-gold-soft bg-white/70'} shadow-soft px-4 py-3 flex items-center justify-center gap-3 transition-all duration-200 hover:shadow-elegant">
            <p class="font-sans text-[10px] font-bold tracking-widest text-foreground/60">STALE</p>
            <p class="font-sans font-bold text-xl text-foreground/60">${stale.length}</p>
            ${activeFilter === 'stale' ? '<p class="font-sans text-[8px] font-bold tracking-widest text-rose-deep">✓ SELECTED</p>' : ''}
          </div>`;

        const listRows =
          activeFilter === 'stale' ? stale :
          activeFilter === null    ? active :
          active.filter(r => activeFilter === 'none' ? r.side === null : r.side === activeFilter);

        const listHtml = `
          <div class="mt-3 rounded-2xl border border-gold-soft bg-white/70 shadow-soft overflow-hidden">
            <div class="max-h-[50vh] overflow-y-auto divide-y divide-gold-soft/50">
              ${listRows.length === 0
                ? '<p class="font-sans font-bold italic text-base text-foreground/60 text-center py-8">Nothing here.</p>'
                : listRows.map(r => `
                  <div class="px-4 py-3 flex items-center justify-between gap-3 ${r.stale ? 'opacity-60' : ''}">
                    <div class="min-w-0">
                      <p class="font-sans font-bold text-base text-foreground truncate"><span class="text-xs font-normal text-foreground/50">${r.id}.</span> ${esc(r.name)}</p>
                      <p class="font-sans text-sm">
                        <span class="${COLOR[r.status]}">${LABEL[r.status]}</span>
                        <span class="text-foreground/60"> — ${r.guest_count} ${r.guest_count === 1 ? 'person' : 'people'}</span>
                      </p>
                    </div>
                    <div class="shrink-0 flex items-center gap-1.5">
                      ${r.stale ? '<span class="font-sans text-[9px] font-bold tracking-widest px-2 py-1 rounded-full border border-foreground/30 text-foreground/60 uppercase">STALE</span>' : ''}
                      ${r.side ? `<span class="font-sans text-[9px] font-bold tracking-widest px-2 py-1 rounded-full border border-gold-soft text-[hsl(95_32%_36%)] uppercase">${r.side}</span>` : ''}
                    </div>
                  </div>`).join('')}
            </div>
          </div>`;

        dash.innerHTML = totalsHtml + sidesHtml + listHtml + staleHtml;
        gate.classList.add('hidden');
        dash.classList.remove('hidden');
        staleAdmin.classList.remove('hidden');
      }

      // Click a box to filter the list; click the selected box again to show all
      dash.addEventListener('click', (e) => {
        const box = (e.target as HTMLElement).closest('[data-filter]') as HTMLElement | null;
        if (!box) return;
        const key = box.dataset.filter as typeof activeFilter;
        activeFilter = activeFilter === key ? null : key;
        render();
      });

      async function loadWithPin(pin: string): Promise<boolean> {
        const body = new FormData();
        body.append('pin', pin);
        const res = await fetch('/api/rsvps-list', { method: 'POST', body });
        if (!res.ok) return false;
        const data = await res.json();
        allRows = data.rows as Row[];
        render();
        return true;
      }

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        errEl.classList.add('hidden');
        submit.disabled = true;
        submit.textContent = 'CHECKING…';
        const pin = input.value.trim();
        const ok = await loadWithPin(pin).catch(() => false);
        if (ok) {
          viewPin = pin;   // in-memory only — refresh always asks again
        } else {
          errEl.textContent = 'Incorrect PIN. Try again.';
          errEl.classList.remove('hidden');
          input.value = '';
          input.focus();
        }
        submit.disabled = false;
        submit.textContent = 'VIEW RESPONSES';
      });

      /* ── Stale toggle ──────────────────────────────────────── */
      staleForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        staleResult.classList.add('hidden');
        staleSubmit.disabled = true;

        const body = new FormData();
        body.append('id', staleId.value.trim());
        body.append('pin', stalePin.value.trim());

        try {
          const res = await fetch('/api/rsvp-stale', { method: 'POST', body });
          const data = await res.json();
          if (res.ok) {
            staleResult.textContent = `#${data.id} ${data.name} → ${data.stale ? 'STALE' : 'ACTIVE'}`;
            staleResult.className = `mt-3 font-sans font-bold text-sm text-center ${data.stale ? 'text-foreground/60' : 'text-[hsl(95_32%_36%)]'}`;
            staleId.value = '';
            // refresh the dashboard with the in-memory view pin
            if (viewPin) await loadWithPin(viewPin);
          } else {
            staleResult.textContent = data.error ?? 'Failed.';
            staleResult.className = 'mt-3 font-sans font-bold text-sm text-center text-red-600';
          }
        } catch {
          staleResult.textContent = 'Network error.';
          staleResult.className = 'mt-3 font-sans font-bold text-sm text-center text-red-600';
        }
        staleResult.classList.remove('hidden');
        staleSubmit.disabled = false;
      });

    </script>
  </body>
</html>
